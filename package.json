{
  "name": "node-boleto",
  "version": "2.3.0",
  "description": "Boleto generator in Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "pretest": "npm run build",
    "lint": "eslint .",
    "test": "nyc --silent --all mocha \"./test/unit/**/*.spec.js\" && nyc --silent --all mocha \"./test/integration/**/*.spec.js\" && nyc --silent --all mocha \"./test/e2e/**/*.spec.js\"",
    "cover-report": "nyc report --reporter=html --reporter=lcov --report-dir=./coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pagarme/node-boleto"
  },
  "dependencies": {
    "ejs": "^5.0.2",
    "moment-timezone": "^0.5.48",
    "qrcode": "^1.5.4"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.19.17",
    "@types/qrcode": "^1.5.6",
    "chai": "^3.5.0",
    "chai-datetime": "^1.4.1",
    "chai-string": "^1.3.0",
    "chai-subset": "^1.4.0",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^6.2.1",
    "eslint-plugin-promise": "^3.3.0",
    "eslint-plugin-standard": "^2.0.1",
    "mocha": "^11.7.5",
    "moment": "^2.30.1",
    "nyc": "15.1.0",
    "ramda": "^0.23.0",
    "typescript": "5.7"
  },
  "author": "Pedro Franceschi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pagarme/node-boleto/issues"
  },
  "homepage": "https://github.com/pagarme/node-boleto",
  "overrides": {
    "serialize-javascript": "7.0.5",
    "diff": "8.0.3"
  }
}
